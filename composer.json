{
    "name": "oktayhaktan0/wp-social-media-automation",
    "description": "Advanced WordPress social media automation plugin",
    "type": "wordpress-plugin",
    "homepage": "https://github.com/oktayhaktan0/Wp-Social-Media-Otomation",
    "license": "GPL-2.0+",
    "authors": [
        {
            "name": "Oktay Haktan",
            "email": "info@haktanoktay.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "composer/installers": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.7",
        "brain/monkey": "^2.6"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/10up/wp_mock.git"
        }
    ],
    "autoload": {
        "psr-4": {
            "WPSMA\\": "includes/"
        }
    },
    "extra": {
        "installer-paths": {
            "vendor/wp-mock/wp-mock": ["wp-mock/wp-mock"]
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "post-install-cmd": [
            "@install-wp-mock"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
